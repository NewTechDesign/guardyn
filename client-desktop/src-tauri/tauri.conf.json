{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Guardyn",
  "version": "0.1.0",
  "identifier": "io.guardyn.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Guardyn",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; script-src 'self'; style-src 'self' 'unsafe-inline'",
      "dangerousDisableAssetCspModification": false
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "flatpak", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "shortDescription": "Secure E2EE Messenger",
    "longDescription": "Guardyn is a privacy-focused secure communication platform with post-quantum encryption.",
    "publisher": "Guardyn",
    "copyright": "Copyright © 2026 Guardyn",
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      },
      "flatpak": {
        "identifier": "io.guardyn.desktop",
        "files": {},
        "finish-args": [
          "--share=ipc",
          "--socket=wayland",
          "--socket=fallback-x11",
          "--socket=pulseaudio",
          "--device=dri",
          "--share=network",
          "--talk-name=org.freedesktop.Notifications",
          "--system-talk-name=org.freedesktop.NetworkManager"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": null,
      "exceptionDomain": null,
      "signingIdentity": null,
      "providerShortName": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "wix": null
    }
  },
  "plugins": {}
}
